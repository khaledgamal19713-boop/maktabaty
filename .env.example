# Environment variables example for Maktabaty
# Rename to .env and provide real values when building/deploying

VITE_SUPA_URL=https://your-project.supabase.co
VITE_SUPA_KEY=public-anon-key-REPLACE_ME

# Optional (for runtime injection into index.html as window.__ENV)
# SUPA_URL and SUPA_KEY can be injected at deploy time for static hosting providers
# Example (Netlify) in _redirects or a snippet that writes <script>window.__ENV=...</script>

# Other optional variables
VITE_APP_NAME=Maktabaty

